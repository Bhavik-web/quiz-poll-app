# ══════════════════════════════════════════════════
# Backend Environment Variables
# ══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════

# MongoDB Connection URI (REQUIRED)
# Get a FREE MongoDB Atlas cluster at: https://www.mongodb.com/atlas
# 1. Create a free M0 cluster
# 2. Create a database user
# 3. Add your IP to the network access list (or use 0.0.0.0/0 for all)
# 4. Click "Connect" → "Connect your application" → copy the URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/quizpoll?retryWrites=true&w=majority

# JWT Secret Key (REQUIRED for production)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_me

# Server Port (optional, defaults to 5000)
PORT=5000

# Frontend URL for CORS (optional, defaults to * in development)
# Set this to your deployed frontend URL in production for security
# FRONTEND_URL=https://your-app.vercel.app
